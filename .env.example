# Copia questo file in .env e inserisci i valori reali
TYPESENSE_URL=https://example.typesense.net
TYPESENSE_API_KEY=YOUR_SECRET_KEY
TYPESENSE_WRITE_API_KEY=YOUR_WRITE_ENABLED_SECRET_KEY
TYPESENSE_COLLECTION=your_collection
TECNOMAT_STORE_SLUG=rimini
TYPESENSE_QUERY_BY=name,sku,mpn
# Esempio filtro store-specifico (adatta al tuo schema)
# TYPESENSE_FILTER_BY=store_id:=116
# Cookie opzionale per forzare il negozio in PDP SSR (esempio)
# TECNOMAT_STORE_COOKIE=tm_store_id=116
# Store ID Tecnomat usato per la PDP SSR (Rimini: 39)
TECNOMAT_STORE_ID=39
